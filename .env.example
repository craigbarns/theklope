# --- Client (exposé au navigateur, préfixe VITE_) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# --- Serveur uniquement (fonctions api/, NE JAMAIS exposer au navigateur) ---
# Clé service_role Supabase : permet au serveur de créer/mettre à jour les commandes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# (optionnel) si l'URL Supabase n'est pas déjà fournie côté serveur :
SUPABASE_URL=https://your-project.supabase.co

# Mollie : clé API (test_xxx en test, live_xxx en production)
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secrets HMAC serveur (valeurs aléatoires distinctes, 32 octets ou plus).
# Le service_role sert de repli, mais des secrets dédiés facilitent leur rotation.
CHECKOUT_IDEMPOTENCY_SECRET=replace-with-at-least-32-random-characters
RATE_LIMIT_SECRET=replace-with-at-least-32-random-characters

# Resend : optionnel, envoi des confirmations commande et alertes internes
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vercel Cron : secret aléatoire d'au moins 16 caractères. Vercel l'envoie
# automatiquement en `Authorization: Bearer ...` à /api/cleanup-checkouts.
CRON_SECRET=replace-with-at-least-32-random-characters

# URL publique du site (pour redirectUrl / webhookUrl Mollie).
# En local avec un tunnel (ngrok) : https://xxxx.ngrok.io
PUBLIC_BASE_URL=https://www.theklope.com
